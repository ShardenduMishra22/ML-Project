PROJECT_NAME=land-risk-ai
COMPOSE_PROJECT_NAME=land-risk-ai

BACKEND_PORT=18080
ML_SERVICE_PORT=18000
FRONTEND_PORT=13000

POSTGRES_DB=landrisk
POSTGRES_USER=landrisk
POSTGRES_PASSWORD=landrisk
POSTGRES_HOST=postgres
POSTGRES_PORT=15432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

KGIS_BASE_URL=https://kgis.ksrsac.in:9000
KGIS_TIMEOUT_SECONDS=8
KGIS_RETRY_COUNT=3
KGIS_CACHE_TTL_SECONDS=1800

REQUEST_TIMEOUT_SECONDS=25
ML_TIMEOUT_SECONDS=10
ML_CACHE_TTL_SECONDS=1800
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_TIMEOUT_SECONDS=8
OPENROUTER_API_KEY=

